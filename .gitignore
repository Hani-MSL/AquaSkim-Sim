# Python
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Local environments and IDE state
.venv/
.env
.vscode/
.idea/

# Operating system
Thumbs.db
Desktop.ini
.DS_Store

# Temporary and lock files
*.tmp
*.bak
*.swp
~$*.docx

# Accidental command-paste files seen in Windows CMD sessions
/cd
/dir
/powershell
/tar
/type
/src_placeholder

# Local/private configuration
config/user_profile.yaml
config/report_metadata.json

# Generated engineering artifacts and audit records.
# They are regenerated by scripts/run_from_zero_to_delivery.bat.
outputs/**
!outputs/.gitkeep
records/**
!records/.gitkeep

# Generated CAD exports
cad/generated/**
!cad/generated/.gitkeep

# Delivery archives and local backups
*.zip
*.7z
*.rar
*_backup*.zip
